# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/spgasbill

# --- Security ---
SECRET_KEY=change-this-secret-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- App ---
APP_NAME=SPBilling API
DEBUG=True
API_PREFIX=/api

# --- Bill numbering ---
BILL_CODE_DEFAULT=BILL

# --- CORS ---
CORS_ORIGINS=*
